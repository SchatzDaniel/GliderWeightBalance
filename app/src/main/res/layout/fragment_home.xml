<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Der Fragment-Container füllt nun den ganzen Bildschirm aus (Z-Index unten) -->

    <!-- Das Dashboard schwebt darüber (Z-Index oben) -->

    <FrameLayout
        android:id="@+id/bottom_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dashboard_header"
        android:paddingBottom="4dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/dashboardLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clipToPadding="false"
            android:clipChildren="false">

            <!-- Karte 1: Schwerpunkt (Volle Breite) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:padding="16dp"
                    android:layout_marginBottom="-8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/labelCg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Schwerpunktlage"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/twSchwerpunktlageErgebnis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/labelCg"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="125.4 mm" />

                    <TextView
                        android:id="@+id/twCgPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        app:layout_constraintBottom_toBottomOf="@id/twSchwerpunktlageErgebnis"
                        app:layout_constraintStart_toEndOf="@id/twSchwerpunktlageErgebnis"
                        app:layout_constraintTop_toTopOf="@id/twSchwerpunktlageErgebnis"
                        tools:text="(25.4%)" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStatusCg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="4dp"
                        app:cardElevation="0dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeWidth="1dp"
                        app:strokeColor="#4CAF50">
                        <TextView
                            android:id="@+id/statusCg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="@string/status_ok"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressCg"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/twSchwerpunktlageErgebnis"
                        app:trackThickness="8dp"
                        app:trackCornerRadius="4dp"
                        app:trackStopIndicatorSize="0dp"
                        app:trackColor="?attr/colorPrimaryInverse"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Container für die zwei unteren Karten (Nebeneinander) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Karte 2: Masse n.t.T -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNonLifting"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/labelNonLifting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/MasseNTTeile"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/twMasseNTTeileErgebnis"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textStyle="bold"
                            app:layout_constraintTop_toBottomOf="@id/labelNonLifting"
                            app:layout_constraintStart_toStartOf="parent"
                            tools:text="450.0 kg" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardStatusNonLifting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="4dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#4CAF50"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:id="@+id/statusNonLifting"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="4dp"
                                android:text="@string/status_ok"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#4CAF50" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressNonLifting"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/twMasseNTTeileErgebnis"
                            app:layout_constraintVertical_bias="1.0"
                            app:trackThickness="6dp"
                            app:trackCornerRadius="3dp"
                            app:trackStopIndicatorSize="0dp"
                            app:trackColor="?attr/colorPrimaryInverse"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Karte 3: Gesamtgewicht -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalMass"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/labelTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Gesamtgewicht"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/twGesamtgewichtOutput"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textStyle="bold"
                            app:layout_constraintTop_toBottomOf="@id/labelTotal"
                            app:layout_constraintStart_toStartOf="parent"
                            tools:text="600.0 kg" />

                        <TextView
                            android:id="@+id/twWingLoading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            app:layout_constraintTop_toBottomOf="@id/twGesamtgewichtOutput"
                            app:layout_constraintStart_toStartOf="parent"
                            android:visibility="gone"
                            tools:visibility="visible"
                            tools:text="Flächenbel.: 35.5 kg/m²" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardStatusTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="4dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#4CAF50"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:id="@+id/statusTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="4dp"
                                android:text="@string/status_ok"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#4CAF50" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressTotal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/twWingLoading"
                            app:layout_constraintVertical_bias="1.0"
                            app:trackThickness="6dp"
                            app:trackCornerRadius="3dp"
                            app:trackStopIndicatorSize="0dp"
                            app:trackColor="?attr/colorPrimaryInverse"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
