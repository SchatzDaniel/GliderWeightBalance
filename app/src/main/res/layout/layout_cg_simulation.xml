<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/simulationContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone"
    tools:visibility="visible">

    <!-- MODUS 1: EINE GRUPPE (Diagramm + Slider) -->
    <LinearLayout
        android:id="@+id/layoutSimSingleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEnvelope"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="?attr/colorSurface">
            <com.danielschatz.gliderweightbalance.views.EnvelopeView
                android:id="@+id/envelopeView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaySimulation"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="0dp"
                app:icon="@drawable/ic_play"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplySimulation"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="0dp"
                app:icon="@drawable/ic_refresh"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                android:layout_marginEnd="4dp"
                app:iconTint="?attr/colorOnPrimary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/simulationSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0"
                android:valueTo="100"
                app:thumbColor="?attr/colorOnPrimary"
                app:trackColorActive="?attr/colorOnPrimary"
                app:trackColorInactive="?attr/colorOnPrimaryContainer" />

            <TextView
                android:id="@+id/tvSimulationTime"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnPrimary"
                tools:text="0:00" />
        </LinearLayout>
    </LinearLayout>

    <!-- MODUS 2: MEHRERE GRUPPEN (Szenario Karten) -->
    <LinearLayout
        android:id="@+id/layoutSimMultiGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOnPrimaryContainer"
            app:cardBackgroundColor="?attr/colorPrimaryContainer">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="@string/info_live_simulation_no_support"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnPrimaryContainer" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/containerExtremeScenarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>

</LinearLayout>
