<resources>

    <style name="Base.Theme.WeightBalance2" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- AppBar / Primary -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- StatusBar -->
        <item name="android:statusBarColor">@color/purple_500</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Icons -->
        <item name="iconColor">@android:color/black</item>
    </style>

    <style name="Theme.WeightBalance2.noActionBar" parent="Base.Theme.WeightBalance2" />

    <style name="ThemeOverlay.App.Toolbar" parent="ThemeOverlay.Material3.Toolbar.Surface">
        <!--
          Setzt die Farbe für alle "Vordergrund"-Elemente.
          Dies betrifft den Titel, das "Zurück"-Icon UND die Menü-Icons.
          Wir verweisen auf die Farbe, die wir in unserem Haupt-Theme definiert haben.
        -->
        <item name="colorOnSurface">?attr/colorOnPrimary</item>
    </style>

    <!-- Custom Style für dicke rote Umrandung im Fehlerfall -->
    <style name="Widget.App.TextInputLayout.ErrorThick" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
        <!-- Wir nutzen boxStrokeWidthFocused, da Material3 die Fehlerranddicke oft intern steuert,
             aber wir erzwingen die generelle Randdicke für Fehler über die Error-Color.
             Eigentlich gibt es kein direktes 'boxStrokeErrorWidth' Attribut in XML ohne Custom View.
             Wir lassen es bei der Standarddicke und setzen die Text-Styles. -->
        <item name="errorTextAppearance">@style/TextAppearance.App.ErrorBold</item>
    </style>

    <style name="TextAppearance.App.ErrorBold" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorError</item>
    </style>

    <style name="TextAppearance.App.SuffixBold" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
