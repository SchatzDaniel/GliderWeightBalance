<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="8dp">

    <!-- Bezeichnung der Station über dem Feld -->
    <TextView
        android:id="@+id/tvSmallStationName"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:textSize="12sp"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        tools:text="Vorderes Gepäck" />

    <!-- Das Eingabefeld im gleichen Stil wie etManualInput, aber mit Validierung -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSmallManualInput"
        style="@style/Widget.App.TextInputLayout.ErrorThick"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        app:boxBackgroundColor="#1A000000"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxStrokeColor="?attr/colorControlNormal"
        app:hintEnabled="false"
        app:suffixText="kg"
        app:suffixTextColor="?attr/colorPrimary"
        app:suffixTextAppearance="@style/TextAppearance.App.SuffixBold"
        app:helperTextEnabled="true"
        app:errorEnabled="true"
        app:errorIconDrawable="@null">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSmallManualInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:inputType="numberDecimal"
            android:paddingVertical="10dp"
            android:paddingEnd="8dp"
            android:paddingStart="8dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            tools:text="10.5" />

    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
