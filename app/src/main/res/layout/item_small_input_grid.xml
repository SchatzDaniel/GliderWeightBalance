<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:padding="8dp">

    <!-- Bezeichnung der Station über dem Feld -->
    <TextView
        android:id="@+id/tvSmallStationName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        tools:text="Vorderes Gepäck" />

    <!-- Das Eingabefeld im gleichen Stil wie etManualInput, aber mit Validierung -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSmallManualInput"
        style="@style/Widget.App.TextInputLayout.ErrorThick"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        app:boxBackgroundColor="@color/md_theme_surfaceContainerHighest"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxStrokeColor="?attr/colorOutline"
        app:hintEnabled="false"
        app:expandedHintEnabled="false"
        app:suffixText="&#160;kg"
        app:suffixTextColor="?attr/colorPrimary"
        app:helperTextEnabled="false"
        app:errorEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSmallManualInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:textAppearance="@style/TextAppearance.App.SuffixBold"
            android:gravity="start|center_vertical"
            android:inputType="numberDecimal"
            android:paddingVertical="12dp"
            android:paddingHorizontal="12dp"
            tools:text="25"
            android:textColor="?attr/colorPrimary"/>

    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
