<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ScrollingFragment">

    <!-- Optional: Ein TextView, das anzeigt, wenn kein Flugzeug ausgewählt ist -->
    <TextView
        android:id="@+id/textView_no_aircraft_selected"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/prompt_no_aircraft_selected"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

    <!-- Die RecyclerView wird alle Eingabefelder für die Stationen enthalten -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView_mass_inputs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_scrolling_station" />

</androidx.constraintlayout.widget.ConstraintLayout>
