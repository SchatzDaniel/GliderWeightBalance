<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Die Hintergrundfarbe (dezent dunkel/grau) -->
    <!-- 1A000000 entspricht ca. 10% Schwarzanteil -->
    <solid android:color="?attr/colorSurfaceContainerHighest" />

    <!-- Die Umrandung (Outline) -->
    <!-- Wir nutzen ?attr/colorControlNormal für ein dezentes Grau,
         oder ?attr/colorPrimary für eine farbige Umrandung -->
    <stroke
        android:width="1dp"
        android:color="?attr/colorOutline" />

    <!-- Abgerundete Ecken (Passend zu Material M3 Standard) -->
    <corners android:radius="8dp" />
</shape>