<PreferenceScreen
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/pref_update_category">
        <ListPreference
            app:defaultValue="beta"
            app:entries="@array/update_channel_entries"
            app:entryValues="@array/update_channel_values"
            app:key="update_channel"
            app:title="@string/pref_update_channel_title"
            app:summary="@string/pref_update_channel_summary"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

</PreferenceScreen>