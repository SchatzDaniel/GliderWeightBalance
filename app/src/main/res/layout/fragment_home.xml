<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Modernes Dashboard in einer Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/dashboardCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dashboardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Schwerpunktlage Sektion -->
            <TextView
                android:id="@+id/twSchwerpunktlage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Schwerpunktlage"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/twSchwerpunktlageErgebnis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@+id/twSchwerpunktlage"
                app:layout_constraintEnd_toStartOf="@+id/twMMHinterBE"
                app:layout_constraintHorizontal_bias="0.8"
                app:layout_constraintStart_toEndOf="@+id/twSchwerpunktlage"
                tools:text="125.4" />

            <TextView
                android:id="@+id/twMMHinterBE"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mmHinterBE"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                app:layout_constraintBaseline_toBaselineOf="@+id/twSchwerpunktlage"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Prozentuale Lage -->
            <TextView
                android:id="@+id/twPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="in Prozent"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/twSchwerpunktlage" />

            <TextView
                android:id="@+id/twPercentResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                app:layout_constraintBaseline_toBaselineOf="@+id/twPercent"
                app:layout_constraintEnd_toEndOf="@+id/twSchwerpunktlageErgebnis"
                tools:text="28.5" />

            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/innerDivider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:dividerColor="?attr/colorOutlineVariant"
                app:layout_constraintTop_toBottomOf="@+id/twPercent" />

            <!-- Gewicht Sektion -->
            <TextView
                android:id="@+id/twMasseNTTeile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/MasseNTTeile"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/innerDivider" />

            <TextView
                android:id="@+id/twMasseNTTeileErgebnis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@+id/twMasseNTTeile"
                app:layout_constraintEnd_toEndOf="@+id/twSchwerpunktlageErgebnis"
                tools:text="450.0" />

            <TextView
                android:id="@+id/twKG1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/kg"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                app:layout_constraintBaseline_toBaselineOf="@+id/twMasseNTTeile"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Gesamtgewicht -->
            <TextView
                android:id="@+id/twGesamtgewicht"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/Gesamtgewicht"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/twMasseNTTeile" />

            <TextView
                android:id="@+id/twGesamtgewichtOutput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                app:layout_constraintBaseline_toBaselineOf="@+id/twGesamtgewicht"
                app:layout_constraintEnd_toEndOf="@+id/twMasseNTTeileErgebnis"
                tools:text="600.0" />

            <TextView
                android:id="@+id/twKG2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/kg"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                app:layout_constraintBaseline_toBaselineOf="@+id/twGesamtgewicht"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Header für die Liste -->
    <TextView
        android:id="@+id/twHeaderStations"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:text="Stationen &amp; Gewichte"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textColor="?attr/colorPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dashboardCard" />

    <!-- Container für das ScrollingFragment -->
    <FrameLayout
        android:id="@+id/bottom_fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/twHeaderStations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>